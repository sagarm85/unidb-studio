# unidb-studio configuration. Copy to `.env.local` and fill in.
# `.env.local` is gitignored (matches *.local) — never commit real tokens.

# Base URL of a reachable unidb-server (no trailing slash needed).
VITE_UNIDB_URL=http://127.0.0.1:8080

# A dev-only HS256 JWT signed with the server's UNIDB_JWT_SECRET.
# Mint one with the engine's helper:
#   TOKEN=$(UNIDB_JWT_SECRET=dev-secret ../unidb/scripts/gen_jwt.sh dev 3600)
#
# WARNING: this token embeds trust in the shared HS256 secret. It is for
# LOCAL DEV ONLY. In production a backend-for-frontend mints short-lived
# tokens server-side; the secret must never ship to a browser bundle.
VITE_UNIDB_TOKEN=
